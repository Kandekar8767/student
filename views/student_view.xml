<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="student_list_view" model="ir.ui.view">
        <field name="name">student.record.list</field>
        <field name="model">student.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="roll_no"/>
                <field name="division"/>
                <field name="standard"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="student_form_view" model="ir.ui.view">
        <field name="name">student.record.form</field>
        <field name="model">student.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="roll_no"/>
                        <field name="division"/>
                        <field name="standard"/>
                        <field name="age"/>
                        <field name="remarks"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action FIRST -->
    <record id="student_record_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="student_management_menu" name="Student Management"/>

    <menuitem id="student_menu"
              name="Students"
              parent="student_management_menu"
              action="student_management.student_record_action"/>

</odoo>
